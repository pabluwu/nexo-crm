# =========================================================================
# NexoProp CRM - Plantilla de Variables de Entorno (.env.example)
# Copie este archivo a '.env' y configure las credenciales correspondientes.
# =========================================================================

# 1. Configuración de Base de Datos MariaDB
DB_ROOT_PASSWORD=nexoproprootpass
DB_NAME=nexoprop
DB_USER=nexopropuser
DB_PASSWORD=nexoproppassword
DB_PORT_HOST=3307

# 2. Configuración de Puerto del Backend NestJS
BACKEND_PORT=3000

# 3. Entorno de Ejecución (development | production)
NODE_ENV=development
